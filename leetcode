#include <iostream>
using namespace std;

bool isPalindrome(int x) {
    // Negative numbers cannot be palindromes
    if (x < 0) {
        return false;
    }

    int original = x;
    long reversed = 0;

    while (x > 0) {
        int digit = x % 10;
        reversed = reversed * 10 + digit;
        x = x / 10;
    }

    return original == reversed;
}

int main() {
    int x = 121;

    if (isPalindrome(x)) {
        cout << "true" << endl;
    } else {
        cout << "false" << endl;
    }

    return 0;
}
