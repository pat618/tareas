#include <iostream>
#include <vector>
#include <unordered_map>
#include <string>
using namespace std;

class Contact {
public:
    int id;
    string name;
    string phone;
    string email;

    Contact(int id, string name, string phone, string email) {
        this->id = id;
        this->name = name;
        this->phone = phone;
        this->email = email;
    }

    void display() {
        cout << "ID: " << id << endl;
        cout << "Name: " << name << endl;
        cout << "Phone: " << phone << endl;
        cout << "Email: " << email << endl;
        cout << "------------------------" << endl;
    }
};

class ContactBook {
private:
    vector<Contact> contacts;
    unordered_map<int, int> parent;
    unordered_map<int, int> rank;
    int nextId;

public:
    ContactBook() {
        nextId = 1;
    }

    void addContact(string name, string phone, string email) {
        Contact newContact(nextId, name, phone, email);
        contacts.push_back(newContact);

        parent[nextId] = nextId;
        rank[nextId] = 0;

        cout << "Contact added successfully with ID: " << nextId << endl;
        nextId++;
    }

    int find(int id) {
        if (parent[id] != id) {
            parent[id] = find(parent[id]);
        }

        return parent[id];
    }

    void unionContacts(int id1, int id2) {
        if (!contactExists(id1) || !contactExists(id2)) {
            cout << "One or both contacts do not exist." << endl;
            return;
        }

        int root1 = find(id1);
        int root2 = find(id2);

        if (root1 == root2) {
            cout << "These contacts are already in the same group." << endl;
            return;
        }

        if (rank[root1] < rank[root2]) {
            parent[root1] = root2;
        }
        else if (rank[root1] > rank[root2]) {
            parent[root2] = root1;
        }
        else {
            parent[root2] = root1;
            rank[root1]++;
        }

        cout << "Contacts have been connected successfully." << endl;
    }

    bool contactExists(int id) {
        for (Contact contact : contacts) {
            if (contact.id == id) {
                return true;
            }
        }

        return false;
    }

    void displayAllContacts() {
        if (contacts.empty()) {
            cout << "No contacts available." << endl;
            return;
        }

        for (Contact contact : contacts) {
            contact.display();
        }
    }

    void searchContactByName(string name) {
        bool found = false;

        for (Contact contact : contacts) {
            if (contact.name == name) {
                contact.display();
                found = true;
            }
        }

        if (!found) {
            cout << "Contact not found." << endl;
        }
    }

    void updateContact(int id, string newName, string newPhone, string newEmail) {
        for (Contact& contact : contacts) {
            if (contact.id == id) {
                contact.name = newName;
                contact.phone = newPhone;
                contact.email = newEmail;

                cout << "Contact updated successfully." << endl;
                return;
            }
        }

        cout << "Contact not found." << endl;
    }

    void deleteContact(int id) {
        for (int i = 0; i < contacts.size(); i++) {
            if (contacts[i].id == id) {
                contacts.erase(contacts.begin() + i);
                parent.erase(id);
                rank.erase(id);

                cout << "Contact deleted successfully." << endl;
                return;
            }
        }

        cout << "Contact not found." << endl;
    }

    void displayContactGroup(int id) {
        if (!contactExists(id)) {
            cout << "Contact does not exist." << endl;
            return;
        }

        int groupRoot = find(id);

        cout << "Contacts in the same group as ID " << id << ":" << endl;

        for (Contact contact : contacts) {
            if (find(contact.id) == groupRoot) {
                contact.display();
            }
        }
    }
};

int main() {
    ContactBook book;
    int option;

    do {
        cout << "\n===== CONTACT BOOK MENU =====" << endl;
        cout << "1. Add Contact" << endl;
        cout << "2. Display All Contacts" << endl;
        cout << "3. Search Contact by Name" << endl;
        cout << "4. Update Contact" << endl;
        cout << "5. Delete Contact" << endl;
        cout << "6. Connect Two Contacts" << endl;
        cout << "7. Display Contact Group" << endl;
        cout << "8. Exit" << endl;
        cout << "Choose an option: ";
        cin >> option;

        cin.ignore();

        if (option == 1) {
            string name, phone, email;

            cout << "Enter name: ";
            getline(cin, name);

            cout << "Enter phone: ";
            getline(cin, phone);

            cout << "Enter email: ";
            getline(cin, email);

            book.addContact(name, phone, email);
        }

        else if (option == 2) {
            book.displayAllContacts();
        }

        else if (option == 3) {
            string name;

            cout << "Enter name to search: ";
            getline(cin, name);

            book.searchContactByName(name);
        }

        else if (option == 4) {
            int id;
            string name, phone, email;

            cout << "Enter contact ID to update: ";
            cin >> id;
            cin.ignore();

            cout << "Enter new name: ";
            getline(cin, name);

            cout << "Enter new phone: ";
            getline(cin, phone);

            cout << "Enter new email: ";
            getline(cin, email);

            book.updateContact(id, name, phone, email);
        }

        else if (option == 5) {
            int id;

            cout << "Enter contact ID to delete: ";
            cin >> id;

            book.deleteContact(id);
        }

        else if (option == 6) {
            int id1, id2;

            cout << "Enter first contact ID: ";
            cin >> id1;

            cout << "Enter second contact ID: ";
            cin >> id2;

            book.unionContacts(id1, id2);
        }

        else if (option == 7) {
            int id;

            cout << "Enter contact ID to see its group: ";
            cin >> id;

            book.displayContactGroup(id);
        }

        else if (option == 8) {
            cout << "Exiting program..." << endl;
        }

        else {
            cout << "Invalid option. Try again." << endl;
        }

    } while (option != 8);

    return 0;
}
